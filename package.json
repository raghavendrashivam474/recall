{
  "name": "recall",
  "displayName": "Recall",
  "description": "The memory layer for software projects. Understand any file in 60 seconds.",
  "version": "0.0.1",
  "publisher": "raghav",
  "author": {
    "name": "Raghav"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other",
    "Education",
    "Visualization"
  ],
  "keywords": [
    "ai",
    "context",
    "memory",
    "codebase",
    "understanding",
    "documentation"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "recall-sidebar",
          "title": "Recall",
          "icon": "resources/recall-icon.svg"
        }
      ]
    },
    "views": {
      "recall-sidebar": [
        {
          "id": "recall.mainView",
          "name": "Recall",
          "type": "webview",
          "contextualTitle": "Recall"
        }
      ]
    },
    "commands": [
      {
        "command": "recall.refresh",
        "title": "Recall: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "recall.showInfo",
        "title": "Recall: Show Info"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "recall.refresh",
          "when": "view == recall.mainView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.0",
    "esbuild": "^0.27.7",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}